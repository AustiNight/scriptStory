{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "scriptstories",
  "main": "server/worker.ts",
  "compatibility_date": "2026-03-09",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "vars": {
    "ENABLE_OPENAI_WRITER": "true"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  }
}
