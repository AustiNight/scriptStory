# Provider API keys (local-only values, never commit real secrets)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local API runtime (single-user loopback defaults)
API_HOST=127.0.0.1
API_PORT=4010

# Feature flags (safe defaults)
ENABLE_OPENAI_WRITER=false
ENABLE_ANTHROPIC_WRITER=false
ENABLE_MCP_CONTEXT=false
